# ─── Sentry env vars ───
# Copy to .env.local and fill in real values. Never commit .env.local.

# Public site URL (used for absolute URLs, metadata, OG)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Server-only (NEVER expose to the browser) ──

# Google AI Studio — Gemini 2.5 Flash
# Get it at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Supabase (conversations + leads + rate limit)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Notion (Now page CMS — https://www.notion.so/my-integrations)
NOTION_API_KEY=
NOTION_NOW_DATABASE_ID=

# Optional: lead notification webhook (Slack, Discord, Telegram, Zapier)
LEAD_NOTIFY_WEBHOOK=

# Gmail SMTP (agent email notifications — free)
# Go to Google Account → Security → App Passwords → Create for "Mail"
SMTP_USER=
SMTP_PASS=
